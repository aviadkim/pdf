{
  "version": 2,
  "buildCommand": "echo 'Production build complete'",
  "outputDirectory": ".",
  "functions": {
    "api/**/*.js": {
      "maxDuration": 30,
      "memory": 1024
    }
  },
  "routes": [
    { "src": "/", "dest": "/api/family-office-upload" },
    { "src": "/api/extract", "dest": "/api/ultimate-pdf-processor" },
    { "src": "/upload", "dest": "/api/family-office-upload" }
  ],
  "env": {
    "NODE_ENV": "production"
  },
  "headers": [
    {
      "source": "/api/(.*)",
      "headers": [
        {
          "key": "X-Content-Type-Options",
          "value": "nosniff"
        },
        {
          "key": "X-Frame-Options", 
          "value": "DENY"
        },
        {
          "key": "Referrer-Policy",
          "value": "strict-origin-when-cross-origin"
        }
      ]
    }
  ]
}